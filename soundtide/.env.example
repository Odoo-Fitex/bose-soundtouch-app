# Pi agent configuration
SOUNDTIDE_HTTP_PORT=7780
SOUNDTIDE_UPNP_PORT=7790
SOUNDTIDE_DATA_DIR=/data
SOUNDTIDE_LOG_LEVEL=info

# Optional: NAS / Synology Wake-on-LAN target (MAC address)
SOUNDTIDE_NAS_WOL_MAC=

# Optional: outbound tunnel to a Cloudflare Worker for off-LAN access.
# Leave both empty for LAN-only.
SOUNDTIDE_WORKER_URL=
SOUNDTIDE_HOUSEHOLD_TOKEN=
