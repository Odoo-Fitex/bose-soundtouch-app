# ── Required ─────────────────────────────────────────────────────────────────
# Time zone for the scheduler. If left at UTC your 7am alarm fires at 7am UTC,
# which is 8am or 9am in most of Europe. Use the IANA zone name.
TZ=Europe/Paris

# ── Defaults you usually don't touch ────────────────────────────────────────
SOUNDTIDE_HTTP_PORT=7780      # PWA-facing REST + WebSocket
SOUNDTIDE_UPNP_PORT=7790      # Embedded UPnP MediaServer HTTP port
SOUNDTIDE_DATA_DIR=/data      # SQLite + cache
SOUNDTIDE_LOG_LEVEL=info      # trace | debug | info | warn | error

# ── Optional: Wake-on-LAN for the Synology NAS ──────────────────────────────
# Enable WOL in DSM (Control Panel → Hardware & Power → Enable WOL on LAN 1)
# then paste the NAS LAN-port MAC here so the "Wake NAS" button works.
SOUNDTIDE_NAS_WOL_MAC=

# ── Optional: outbound tunnel to the Cloudflare Worker for off-LAN access ───
# Leave both blank for LAN-only operation.
SOUNDTIDE_WORKER_URL=
SOUNDTIDE_HOUSEHOLD_TOKEN=
