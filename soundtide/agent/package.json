{
  "name": "soundtide-agent",
  "version": "0.1.0",
  "private": true,
  "description": "LAN agent for SoundTide — runs on a Raspberry Pi, drives Bose SoundTouch speakers.",
  "license": "MIT",
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc -p . --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "bonjour-service": "^1.2.1",
    "cron-parser": "^4.9.0",
    "fast-xml-parser": "^4.5.0",
    "fastify": "^5.0.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.2",
    "@fastify/websocket": "^11.0.0",
    "node-fetch": "^3.3.2",
    "wol": "^1.0.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
